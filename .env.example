# A Velanto Personal Access Token — create one at https://playvelanto.com/settings
# (the "API tokens" section). Treat it like a password.
VELANTO_API_TOKEN=vlt_pat_...

# The Velanto API base URL. Defaults to the production API.
# For local development against a dev backend, use http://localhost:3001
VELANTO_API_URL=https://api.playvelanto.com
